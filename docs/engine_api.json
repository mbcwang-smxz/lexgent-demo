{
    "name": "LexGent Engine",
    "version": "1.0.0",
    "description": "Configuration-driven AI Agent execution engine",
    "endpoints": [
        {
            "method": "GET",
            "path": "/health",
            "description": "Health check",
            "response": "OK"
        },
        {
            "method": "GET",
            "path": "/info",
            "description": "API reference (this endpoint)"
        },
        {
            "method": "GET",
            "path": "/agent/:agentId/skills",
            "description": "List available skills for an agent",
            "response": "{ [skillId]: { query, desc, alias?, params? } }"
        },
        {
            "method": "GET",
            "path": "/agent/:agentId/functions",
            "description": "List available functions for an agent",
            "response": "{ [funcId]: { desc, alias?, params? } }"
        },
        {
            "method": "GET",
            "path": "/agent/:agentId/tasks",
            "description": "List available tasks for an agent",
            "response": "{ [taskId]: { desc, alias?, params? } }"
        },
        {
            "method": "POST",
            "path": "/agent/:agentId/clear-cache",
            "description": "Clear LLM response cache"
        },
        {
            "method": "POST",
            "path": "/agent/:agentId/run",
            "description": "Direct task execution (non-session mode)",
            "body": {
                "caseId": {
                    "type": "string",
                    "required": true
                },
                "query": {
                    "type": "string",
                    "required": true
                },
                "verbose": {
                    "type": "boolean",
                    "required": false
                },
                "reuseSandbox": {
                    "type": "boolean",
                    "required": false
                },
                "sessionBase": {
                    "type": "number",
                    "required": false,
                    "description": "Timestamp to filter chat history"
                },
                "sessionId": {
                    "type": "string",
                    "required": false,
                    "description": "Session ID for SSE streaming"
                }
            },
            "response": "{ status: \"started\", caseId, taskId }"
        },
        {
            "method": "POST",
            "path": "/agent/:agentId/execute_command",
            "description": "Execute a skill/function/task command within a session",
            "body": {
                "sessionId": {
                    "type": "string",
                    "required": true
                },
                "command": {
                    "type": "string",
                    "required": false,
                    "description": "\"skill\" | \"function\""
                },
                "targetId": {
                    "type": "string",
                    "required": true
                },
                "args": {
                    "type": "string",
                    "required": false
                }
            },
            "response": "{ status: \"started\", taskId }"
        },
        {
            "method": "POST",
            "path": "/session",
            "description": "Create a new session",
            "body": {
                "caseNumber": {
                    "type": "string",
                    "required": true
                },
                "caseId": {
                    "type": "string",
                    "required": true
                },
                "agentId": {
                    "type": "string",
                    "required": false,
                    "description": "Defaults to configured default agent"
                },
                "configId": {
                    "type": "string",
                    "required": false,
                    "description": "Runtime config ID (from agent configs)"
                },
                "yamlServerUrl": {
                    "type": "string",
                    "required": false,
                    "description": "YAML Server endpoint, falls back to env/default"
                },
                "dataServerUrl": {
                    "type": "string",
                    "required": false,
                    "description": "Data Server endpoint, falls back to agent config/env/default"
                },
                "verbose": {
                    "type": "boolean",
                    "required": false
                },
                "reuseSandbox": {
                    "type": "boolean",
                    "required": false
                }
            },
            "response": "{ sessionId, caseId, agentId, status }"
        },
        {
            "method": "GET",
            "path": "/session/:sessionId/events",
            "description": "SSE event stream for a session",
            "response": "SSE stream. Event types: log, error, ask, progress, complete, action"
        },
        {
            "method": "POST",
            "path": "/session/:sessionId/task",
            "description": "Submit a task to an active session",
            "body": {
                "query": {
                    "type": "string",
                    "required": true
                }
            },
            "response": "{ taskId, status: \"started\" }"
        },
        {
            "method": "POST",
            "path": "/session/:sessionId/reply",
            "description": "Reply to a pending ask from the agent",
            "body": {
                "askId": {
                    "type": "string",
                    "required": true
                },
                "input": {
                    "type": "string",
                    "required": true
                }
            },
            "response": "{ ok: true }"
        },
        {
            "method": "DELETE",
            "path": "/session/:sessionId",
            "description": "Close and delete a session",
            "response": "{ ok: true|false }"
        }
    ]
}